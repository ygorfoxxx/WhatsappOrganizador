# Porta do servidor
PORT=3000

# Banco de dados
# Local (SQLite):
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"
# Railway/Produção (PostgreSQL) - descomentar:
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# IA - Escolha um provedor e preencha a chave correspondente

# Google Gemini (padrão, gratuito com limites generosos)
GEMINI_API_KEY=sua-chave-gemini-aqui

# OpenAI (opcional, pago)
# OPENAI_API_KEY=sk-sua-chave-aqui

# Provedor ativo: "gemini" (padrão) ou "openai"
AI_PROVIDER=gemini

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=financa-fox
EVOLUTION_API_KEY=sua-chave-evolution-aqui

# Timezone
TZ=America/Sao_Paulo
